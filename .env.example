# RevenueCat platform API keys — required for production App Store / Play Store builds.
# Get these from RevenueCat → Project Settings → API keys (iOS / Android, not Test Store).
# Development uses the Test Store key automatically when __DEV__ is true.

EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# Supabase — cloud save (see doc/SUPABASE_PLAN.md)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

BD_PASSWORD=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=